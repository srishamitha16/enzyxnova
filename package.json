{
  "name": "enzyxnova",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron-dev": "electron .",
    "electron-build": "vite build && electron-builder",
    "electron-builder": "electron-builder --win --publish never"
  },
  "build": {
    "appId": "com.enzyxnova.app",
    "productName": "EnzyXNova",
    "directories": {
      "buildResources": "assets",
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "axios": "^1.6.0",
    "framer-motion": "^11.0.0",
    "lucide-react": "^1.16.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.15.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.4",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^latest",
    "electron-builder": "^latest",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.5",
    "typescript": "^5.5.3",
    "vite": "^5.4.0"
  }
}
